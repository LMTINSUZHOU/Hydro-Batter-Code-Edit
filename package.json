{
  "name": "hydro-batter-code-edit",
  "version": "1.3.4",
  "description": "IDE-like HydroOJ Monaco enhancements with clangd, Pyright, JDT LS, Tree-sitter fallback, formatting, diagnostics and autosave.",
  "main": "index.ts",
  "type": "commonjs",
  "files": [
    "frontend",
    "src",
    "index.ts",
    "types.ts",
    "install.sh",
    "uninstall.sh",
    "runtime.nix",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check": "npm run typecheck && npm test"
  },
  "engines": {
    "node": ">=22"
  },
  "os": [
    "linux"
  ],
  "peerDependencies": {
    "@hydrooj/ui-default": ">=4.58.0",
    "hydrooj": ">=5.0.0"
  },
  "devDependencies": {
    "@hydrooj/ui-default": "4.58.4",
    "@types/node": "^24.10.0",
    "esbuild": "0.25.2",
    "hydrooj": "5.0.4",
    "monaco-editor": "0.52.2",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/LMTINSUZHOU/Hydro-Batter-Code-Edit.git"
  },
  "keywords": [
    "hydrooj",
    "hydro-plugin",
    "monaco-editor",
    "language-server-protocol",
    "online-judge"
  ],
  "author": "Albert_Li <lmt_in_suzhou@outlook.com>",
  "license": "MIT",
  "dependencies": {
    "pyright": "1.1.411",
    "tree-sitter-cpp": "0.23.4",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-python": "0.25.0",
    "web-tree-sitter": "0.26.10"
  }
}
